    "branded_share": { "value": 0.62, "definition": "Share of treated eyes sourced from branded anti-VEGF use rather than low-cost/off-label use." },
    "mortality_attrition": { "value": 0.03, "definition": "Annual loss from mortality and aging-related patient attrition." },
    "clinical_loss": { "value": 0.015, "definition": "Annual loss from eyes no longer clinically suitable for the modeled durable option." },
    "competitive_loss": { "value": 0.015, "definition": "Annual loss from durable-option candidates choosing other management or future competitors." },
    "fellow_conversion": { "value": 0.1, "definition": "Annual conversion of at-risk fellow eyes into the modeled source pool." },
    "fellow_at_risk_share": { "value": 0.35, "definition": "Share of modeled patients with an at-risk fellow-eye opportunity." }
