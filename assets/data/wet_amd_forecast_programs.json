  "segments": [
    {
      "id": "HB branded",
      "label": "High-burden branded anti-VEGF source",
      "definition": "Eyes currently treated with branded anti-VEGF therapy and carrying high treatment burden before durable-option consideration, access, adoption, and product allocation."
    },
    {
      "id": "HB low-cost",
      "label": "High-burden low-cost anti-VEGF source",
      "definition": "Eyes currently sourced from low-cost or off-label anti-VEGF treatment. This is a source-of-business pool, not a lower-price disease category."
    },
    {
      "id": "Lower-burden branded",
      "label": "Lower-burden branded anti-VEGF source",
      "definition": "A smaller branded-source expansion pool for eyes not modeled as the high-burden launch core."
    }
  ],
